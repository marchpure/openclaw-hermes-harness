# ============================================================
# Hermes Agent 环境变量配置
# 复制为 .env 并填入实际值
# ============================================================

# ─── 用户映射 (匹配宿主 UID/GID) ───────────────────────────
HERMES_UID=1000
HERMES_GID=1000

# ─── 资源限制 ──────────────────────────────────────────────
HERMES_CPU_LIMIT=2.0
HERMES_MEM_LIMIT=4G

# ─── LLM 配置 (火山方舟 ARK - MiniMax M2.5) ───────────────
# 使用 OpenAI-compatible API 格式
# 在 data/config.yaml 中配置模型，这里只放 API Key
OPENAI_API_KEY=your-ark-api-key-here
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ─── 可选: OpenRouter ──────────────────────────────────────
# OPENROUTER_API_KEY=

# ─── 可选: Google Gemini ───────────────────────────────────
# GOOGLE_API_KEY=

# ─── 可选: MiniMax 直连 ───────────────────────────────────
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
