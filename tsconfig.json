{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["./*.ts", "./src/**/*.ts", "./test-support/**/*.ts"],
  "exclude": ["./dist/**", "./node_modules/**"]
}
