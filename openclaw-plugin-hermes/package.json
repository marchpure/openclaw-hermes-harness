{
  "name": "openclaw-plugin-hermes",
  "version": "2.0.0",
  "type": "module",
  "description": "OpenClaw plugin — delegate heavy tasks to containerized Hermes Agent via ACP",
  "main": "dist/index.js",
  "files": [
    "src/",
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "AGENTS.md",
    "tsconfig.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2"
    },
    "permissions": {
      "reason": "Plugin delegates tasks to a containerized Hermes Agent via Docker exec and ACP TCP/stdio transport. child_process is required for docker exec (health checks, stdio ACP transport) and net module for TCP ACP transport.",
      "requires": [
        "child_process",
        "net"
      ]
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "npx tsc"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0"
  }
}
